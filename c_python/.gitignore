.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

.env
.env.local

# Model weights and trained models (large binaries)
*.pt
*.joblib
models/

# Exception: keep production weights so Render can load them on deploy.
# Each new training run bumps the version suffix and adds another exception.
!weights/best.pt
!weights/cost_estimation.v*.joblib

# Model cards are tiny JSON sidecars — always track them
!weights/*.json

# Inference logs (JSONL, generated at runtime)
logs/

# Local test harness (input images, output annotations, ad-hoc scripts)
test/

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
Thumbs.db
*.log
