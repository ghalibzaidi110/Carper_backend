# Copy to .env and adjust. Used by the damage-detection service (Nest calls this at DAMAGE_DETECTION_SERVICE_URL).

# Server
PORT=8000
HOST=0.0.0.0

# Optional: path to YOLOv8 model weights (e.g. damage.pt). If unset, API returns stub responses.
# MODEL_PATH=./models/damage.pt

# Optional: log level
# LOG_LEVEL=info
