# Copy to .env and adjust. Used by the damage-detection service (Nest calls this at DAMAGE_DETECTION_SERVICE_URL).

# Server
PORT=8000
HOST=0.0.0.0

# YOLOv8 model: best.pt inside c_python/weights/
MODEL_PATH=weights/best.pt

# Optional: inference tuning (match training)
# CONF_THRESHOLD=0.25
# IOU_THRESHOLD=0.45
# IMGSZ=1024
# MAX_DET=300

# Optional: log level
# LOG_LEVEL=info
