# Copy this file to .env and fill in real values.
# Required for the app to start:
# For Neon/SSL use: ...?sslmode=require (or ?uselibpqcompat=true&sslmode=require to silence libpq warning)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-required
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-required

# Optional (defaults)
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
PORT=3000
FRONTEND_URL=http://localhost:3001

# Image uploads (CNIC, avatar, car images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Damage detection (YOLOv8 service)
DAMAGE_DETECTION_SERVICE_URL=http://localhost:8000

# Email (console = log only)
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@carplatform.pk

# Admin seed (npm run seed)
ADMIN_EMAIL=admin@carplatform.pk
ADMIN_PASSWORD=Admin@123456

# OAuth (optional – omit to run without Google/Facebook login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_CALLBACK_URL=http://localhost:3000/api/v1/auth/facebook/callback
